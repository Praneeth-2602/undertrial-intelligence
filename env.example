# ─────────────────────────────────────────────────────────────────────────────
# Undertrial Intelligence System — Environment Variables
# Copy this file to .env in the project root and fill in your values.
# ─────────────────────────────────────────────────────────────────────────────


# ── Groq (Eligibility + Rights agents) ───────────────────────────────────────
# Get your free key at: https://console.groq.com
GROQ_API_KEY=your_groq_api_key_here
GROQ_MODEL=llama-3.3-70b-versatile


# ── Google Gemini (Advocate + Critic agents) ──────────────────────────────────
# Get your free key at: https://aistudio.google.com
GOOGLE_API_KEY=your_google_api_key_here
GEMINI_MODEL=gemini-2.0-flash-exp


# ── Ollama (local embeddings) ─────────────────────────────────────────────────
# Install Ollama: https://ollama.com
# Then run: ollama pull nomic-embed-text
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_EMBED_MODEL=nomic-embed-text


# ── Indian Kanoon API ─────────────────────────────────────────────────────────
# Register at: https://api.indiankanoon.org (paid, usage-billed)
# Leave blank to disable Kanoon ingestion — PDF ingestion will still work.
INDIAN_KANOON_API_TOKEN=your_indiankanoon_token_here
INDIAN_KANOON_API_BASE=https://api.indiankanoon.org

# Max documents to fetch per search query (keeps costs low)
INDIAN_KANOON_MAX_DOCS_PER_QUERY=5

# Of those, how many to fetch full text for (vs. snippet only)
INDIAN_KANOON_FULLTEXT_DOCS_PER_QUERY=2

# Seconds to wait between full-text fetches (respect rate limits)
INDIAN_KANOON_RATE_LIMIT_SECONDS=0.35


# ── Storage paths ─────────────────────────────────────────────────────────────
# ChromaDB vector store (auto-created on first run)
CHROMA_PERSIST_DIR=./data/chroma_db

# Ingestion deduplication log (auto-created on first run)
INGESTION_LOG_PATH=./data/ingestion_log.json
